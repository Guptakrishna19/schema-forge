# Copy to `.env` for local development.

# HTTP server bind address
SCHEMA_FORGE_BIND=0.0.0.0:8080

# PostgreSQL
DATABASE_URL=postgres://schemaforge:schemaforge@localhost:5432/schemaforge

# Apache Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_DOMAIN_TOPIC=schemaforge.domain-events

# Logging (tracing EnvFilter syntax)
RUST_LOG=info,schema_forge=debug
